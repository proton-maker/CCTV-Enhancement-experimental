# Local / runtime
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Restored outputs (regenerable)
Restored/
*.orig.mp4
*.orig.mkv

# work/ is committed bakeoff data — exclude bulky / temp only
work/archive/
work/_tmp*/
work/**/intermediate/
work/**/rvrt_in/

# Raw Originals that exceed GitHub ~100MB — use Original/packs/ (ZIP_STORED split)
Original/ch07.mp4

# Third-party tools — clone locally (see tools/README.md)
tools/*
!tools/README.md

# OS / editor
.DS_Store
Thumbs.db
*.log

# Secrets
.env
*.pem
credentials.json
